{
  "name": "socratize",
  "version": "1.0.0",
  "bin": {
    "socratize": "bin/socratize.js"
  },
  "files": [
    "bin/",
    "dist/",
    ".next/server/",
    ".next/static/",
    ".next/build/",
    ".next/node_modules/",
    ".next/*.json",
    ".next/BUILD_ID",
    ".next/package.json",
    "public/",
    "next.config.mjs",
    "prisma/migrations/",
    "prisma/schema.prisma",
    "prisma.config.ts"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build && node scripts/fix-externals.js && esbuild server.ts --bundle --packages=external --platform=node --format=cjs --outfile=dist/server.cjs",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "postinstall": "prisma generate && for f in node_modules/node-pty/prebuilds/*/spawn-helper; do chmod +x \"$f\" 2>/dev/null || true; done"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "next": "^16.2.2",
    "node-pty": "^1.1.0",
    "open": "^8.4.2",
    "openai": "^6.33.0",
    "prisma": "^7.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
