// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

// Note: Prisma v7 moves the database URL out of schema.prisma.
// The URL is configured in prisma.config.ts via defineConfig({ datasource: { url } }).
// Adding url = env("DATABASE_URL") here would conflict with prisma.config.ts (error P1012).
datasource db {
  provider = "sqlite"
}

model ChatSession {
  id                  String                @id @default(cuid())
  title               String
  llmProvider         String                @default("anthropic")
  model               String                @default("claude-sonnet-4-6")
  extractionMode      String                @default("guided")
  knowledgeFolderPath String                @default("")
  conversations       SessionConversation[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model Message {
  id             String              @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  docOps         String? // JSON string of DocOp[]
  toolHistory    String? // JSON string of intermediate tool call/result messages for KB sessions
  sessionConv    SessionConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())

  @@index([conversationId])
}

model SessionConversation {
  id        String      @id @default(cuid())
  sessionId String
  title     String      @default("New conversation")
  messages  Message[]
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([sessionId])
}

model ApiKey {
  id           String   @id @default(cuid())
  provider     String   @unique // "anthropic" | "openai"
  encryptedKey String
  createdAt    DateTime @default(now())
}

model Sandbox {
  id                  String                @id @default(cuid())
  name                String
  skillFolderPath     String                @default("") // single absolute folder path
  workspaceFolderPath String
  conversations       SandboxConversation[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model SandboxMessage {
  id             String              @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  toolHistory    String? // JSON: intermediate tool_use/tool_result MessageParam[] for this exchange
  createdAt      DateTime            @default(now())
  sandboxConv    SandboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model SandboxConversation {
  id        String           @id @default(cuid())
  sandboxId String
  title     String           @default("New conversation")
  messages  SandboxMessage[]
  sandbox   Sandbox          @relation(fields: [sandboxId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([sandboxId])
}
