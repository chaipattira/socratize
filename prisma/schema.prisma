// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

// Note: Prisma v7 moves the database URL out of schema.prisma.
// The URL is configured in prisma.config.ts via defineConfig({ datasource: { url } }).
// Adding url = env("DATABASE_URL") here would conflict with prisma.config.ts (error P1012).
datasource db {
  provider = "sqlite"
}

model ChatSession {
  id          String    @id @default(cuid())
  title       String
  llmProvider String    @default("anthropic")
  model       String    @default("claude-sonnet-4-6")
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String      // "user" | "assistant"
  content       String
  docOps        String?     // JSON string of DocOp[]
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([chatSessionId])
}

model ApiKey {
  id           String   @id @default(cuid())
  provider     String   @unique // "anthropic" | "openai"
  encryptedKey String
  createdAt    DateTime @default(now())
}
